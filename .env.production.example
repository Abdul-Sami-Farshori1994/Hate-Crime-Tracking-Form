# Copy to .env (or set in your hosting platform) before production go-live.
# Never commit real secrets.

ENVIRONMENT=production
SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32_OR_LONG_RANDOM_STRING
CORS_ORIGINS=https://your-forms-site.example
ALLOW_DEFAULT_USER_SEED=false
ACCESS_TOKEN_EXPIRE_MINUTES=30
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database (internal URL when API runs in Docker on same network)
DATABASE_URL=postgresql+asyncpg://postgres:STRONG_PASSWORD@db:5432/hatecrime

# Postgres container (docker-compose.yml)
POSTGRES_PASSWORD=STRONG_PASSWORD

# Frontend path slugs (rebuild web after changing). Generate: openssl rand -base64 24
VITE_FORM_PATH_SLUG=REPLACE_WITH_UNIQUE_FORM_SLUG
VITE_ADMIN_PATH_SLUG=REPLACE_WITH_UNIQUE_ADMIN_SLUG

# Optional: require consent checkbox on form (set VITE_CONSENT_REQUIRED=true at frontend build)
CONSENT_REQUIRED=false

# Optional: shared rate limits across API replicas
# REDIS_URL=redis://redis:6379/0

# Login lockout (per username)
# LOGIN_MAX_FAILURES=5
# LOGIN_LOCKOUT_MINUTES=15

# Max JSON request body size in bytes (default 1048576 = 1 MiB)
# MAX_REQUEST_BODY_BYTES=1048576

# Phase 2 — cookie sessions, MFA, refresh tokens
USE_COOKIE_AUTH=true
COOKIE_SECURE=true
ACCESS_TOKEN_EXPIRE_MINUTES_ADMIN=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_MFA_REQUIRED=true
# MFA_ISSUER_NAME=Hate Crime Tracking Form
# ADMIN_IP_ALLOWLIST=203.0.113.10,203.0.113.11
# ADMIN_LOGIN_WEBHOOK_URL=https://hooks.example.com/admin-login
