# Leave empty in development: Vite proxies API paths only (see vite.config.ts), not /form or /admin pages.
# Production: set to your API origin if not same-host (e.g. https://api.example.org)
VITE_API_BASE_URL=

# Unguessable URL path slugs (16–64 chars: A–Z, a–z, 0–9, _, -). Generate: openssl rand -base64 24
# Dev defaults below; set unique values in production and rebuild the web image.
VITE_FORM_PATH_SLUG=Kp9mNx2vQw7Rt4yL8bHc1dF
VITE_ADMIN_PATH_SLUG=Hn3qWz8cRm6Tk5xP2vJk4mN

# Show consent checkbox before submit (match API CONSENT_REQUIRED in production builds)
# VITE_CONSENT_REQUIRED=true

# Optional: override logo URL (default: bundled /logo.png from Karwan e Mohabbat)
# VITE_APP_LOGO_URL=https://karwanemohabbat.in/wp-content/uploads/2020/05/Logo.png
