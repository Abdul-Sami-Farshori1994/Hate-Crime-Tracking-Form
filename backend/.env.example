# Local API on host + Postgres from Docker (use dev overlay for port 5433):
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/hatecrime

# Optional: local dev without Docker (no Alembic; API creates SQLite schema on startup)
# DATABASE_URL=sqlite+aiosqlite:///./hatecrime_dev.db

# Required — use a long random string (32+ chars) in production
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# development | production
ENVIRONMENT=development

# Comma-separated browser origins allowed to call the API (required in production)
# CORS_ORIGINS=https://your-domain.example

# Seed admin/admin and user/user only when the users table is empty (false in production)
ALLOW_DEFAULT_USER_SEED=true

# Logging: stdout only (no log files). json recommended for production aggregators.
# LOG_LEVEL=DEBUG
# LOG_FORMAT=text
